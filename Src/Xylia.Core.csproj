<Project Sdk="Microsoft.NET.Sdk">
	<PropertyGroup>
		<TargetFramework>net5.0-windows</TargetFramework>
		<OutputType>Library</OutputType>
		<RootNamespace>Xylia</RootNamespace>
		<AssemblyName>Xylia</AssemblyName>
		<UseWindowsForms>true</UseWindowsForms>
		<ImportWindowsDesktopTargets>true</ImportWindowsDesktopTargets>
		<Deterministic>false</Deterministic>
		<Version>1.0.3.1</Version>
		<AssemblyVersion>1.0.2.*</AssemblyVersion>
	</PropertyGroup>



	<ItemGroup>
		<Reference Include="HtmlAgilityPack, Version=1.4.6.0, Culture=neutral, PublicKeyToken=bd319b19eaf3b43a, processorArchitecture=MSIL">
			<SpecificVersion>False</SpecificVersion>
			<HintPath>..\..\..\..\..\Public\HtmlAgilityPack.dll</HintPath>
		</Reference>
		<Reference Include="HZH_Controls">
			<HintPath>..\..\..\net_winform_custom_control\HZH_Controls\HZH_Controls\bin\Release\net5.0-windows\HZH_Controls.dll</HintPath>
		</Reference>
	</ItemGroup>
	<ItemGroup>
		<Compile Include="Files\.Excel\ExcelInfo.cs" />
		<Compile Include="Files\.Excel\Extension\Row.cs" />
		<Compile Include="Files\.Excel\Extension\Cell.cs" />
		<Compile Include="Files\.Excel\Extension\Sheet.cs" />
		<Compile Include="Files\.Excel\IStyle.cs" />
		<Compile Include="Files\.Xml\INode.cs" />
		<Compile Include="Files\.Xml\XmlInfo.cs" />
		<Compile Include="Files\.Xml\XmlProperty.cs" />
		<Compile Update="Properties\Resources\Resource.Designer.cs">
			<DesignTime>True</DesignTime>
			<AutoGen>True</AutoGen>
			<DependentUpon>Resource.resx</DependentUpon>
		</Compile>
		<Compile Update="Windows\Controls\Treeview.cs" />
		<Compile Update="Windows\Forms\Editor\CustomRichTextBox.cs">
			<SubType>Component</SubType>
		</Compile>
		<Compile Update="Windows\Forms\Editor\Settings.Designer.cs">
			<DesignTimeSharedInput>True</DesignTimeSharedInput>
			<AutoGen>True</AutoGen>
			<DependentUpon>Settings.settings</DependentUpon>
		</Compile>
	</ItemGroup>
	<ItemGroup>
		<PackageReference Include="MetroFramework" Version="1.2.0.3" />
		<PackageReference Include="Newtonsoft.Json" Version="13.0.2" />
		<PackageReference Include="NPOI" Version="2.6.0" />
	</ItemGroup>

	<ItemGroup>
		<EmbeddedResource Update="Properties\Resources\Resource.resx">
			<Generator>ResXFileCodeGenerator</Generator>
			<LastGenOutput>Resource.Designer.cs</LastGenOutput>
		</EmbeddedResource>
	</ItemGroup>
	<ItemGroup>
		<None Update="Windows\Forms\Editor\Settings.settings">
			<Generator>PublicSettingsSingleFileGenerator</Generator>
			<LastGenOutput>Settings.Designer.cs</LastGenOutput>
		</None>
	</ItemGroup>
</Project>